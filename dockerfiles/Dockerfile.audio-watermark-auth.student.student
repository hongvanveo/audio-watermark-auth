FROM labtainers/labtainer.base2:latest
LABEL version="1" base="labtainers/labtainer.base2.739eee77f8d3"
USER root
ARG lab
ARG labdir
ARG imagedir
ENV HOME /home/ubuntu
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
    ffmpeg \
    sox \
    python3 \
    && rm -rf /var/lib/apt/lists/*
RUN useradd -m -s /bin/bash ubuntu || true
WORKDIR /home/ubuntu
ADD $labdir/$lab.tar.gz /home/ubuntu
RUN chown -R ubuntu:ubuntu /home/ubuntu \
    && chmod +x /home/ubuntu/stego/*.py \
    && printf '\npython3 ~/stego/refresh_status.py >/dev/null 2>&1 || true\nPROMPT_COMMAND="python3 ~/stego/refresh_status.py >/dev/null 2>&1 || true${PROMPT_COMMAND:+;$PROMPT_COMMAND}"\n' >> /home/ubuntu/.bashrc
